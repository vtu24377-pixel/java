import java.util.*;

public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        String s=sc.next();
        String period=s.substring(8);
        int h=Integer.parseInt(s.substring(0,2));
        if(period.equals("AM")){
            if(h==12) h=0;
        }else{
            if(h!=12) h+=12;
        }
        System.out.printf("%02d%s\n",h,s.substring(2,8));
    }
}
