import java.util.*;
import java.util.stream.*;

public class Main{
    static boolean isPrime(int n){
        if(n<2) return false;
        for(int i=2;i*i<=n;i++){
            if(n%i==0) return false;
        }
        return true;
    }
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int a=sc.nextInt();
        int b=sc.nextInt();
        long c=IntStream.rangeClosed(a,b).filter(x->isPrime(x)).count();
        System.out.println(c);
    }
}
