import java.util.Scanner;
import java.util.function.Predicate;

public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        Predicate<Integer> p=x->{
            int t=x,r=0;
            while(t>0){
                r=r*10+t%10;
                t/=10;
            }
            return r==x;
        };
        System.out.println(p.test(n));
    }
}
