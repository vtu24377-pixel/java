import java.util.*;

public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        String s=sc.next();
        int[] arr=new int[10];
        for(char c:s.toCharArray()) arr[c-'0']++;
        for(int i=0;i<10;i++) System.out.println(i+" "+arr[i]);
    }
}
