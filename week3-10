import java.util.*;

public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int res=0;
        boolean add=true;
        for(int i=1;i<=n;i++){
            if(add) res+=i;
            else res-=i;
            add=!add;
        }
        System.out.println(res);
    }
}
