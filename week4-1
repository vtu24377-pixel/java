import java.util.*;

public class Main{
    public static boolean halvesAreAlike(String s){
        Set<Character> v=new HashSet<>(Arrays.asList('a','e','i','o','u','A','E','I','O','U'));
        int mid=s.length()/2,c1=0,c2=0;
        for(int i=0;i<mid;i++) if(v.contains(s.charAt(i))) c1++;
        for(int i=mid;i<s.length();i++) if(v.contains(s.charAt(i))) c2++;
        return c1==c2;
    }
}
